# 环境变量配置示例
# 复制为 .env 并填写实际值

# ==================== MiniMax API（必须）====================
# API Key（用于 Chat 对话）
MINIMAX_API_KEY=你的MiniMax_API_Key

# GroupID + SecretID（用于 TTS 和 ASR）
# 在 MiniMax 控制台 → API Key 页面获取
MINIMAX_GROUP_ID=你的GroupID
MINIMAX_SECRET_ID=你的SecretID

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== JWT ====================
JWT_SECRET=你的JWT密钥（生产环境必须修改）

# ==================== 服务 ====================
DEBUG=false
LOG_LEVEL=INFO

# ============================================================
# DeepSeek 主 LLM（2026-05-14 接入，首字 ~500ms 极速）
# 申请：https://platform.deepseek.com/api_keys
# ============================================================
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_PROVIDER=deepseek
