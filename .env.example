# 运营后台
ADMIN_TOKEN=your_admin_token_here

# 微信小程序
WX_APP_ID=your_wx_app_id
WX_APP_SECRET=your_wx_app_secret

# 阿里云/千问大模型
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscale.aliyuncs.com/compatible-mode/v1

# 腾讯云（ASR 语音识别 + TTS 语音合成）
TENCENTCLOUD_APP_ID=your_tencent_app_id
TENCENTCLOUD_SECRET_ID=your_tencent_secret_id
TENCENTCLOUD_SECRET_KEY=your_tencent_secret_key
TENCENTCLOUD_REGION=ap-guangzhou

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 密钥（生产环境必须修改）
JWT_SECRET=change-me-in-production
