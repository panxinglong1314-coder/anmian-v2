/* pages/profile/profile.wxss - 个人中心 */

.page {
  min-height: 100vh;
  background-color: #0D1B2A;
  padding-bottom: 60rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #0D1B2A;
  border-bottom: 1rpx solid rgba(139, 163, 185, 0.1);
}
.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-back-icon {
  font-size: 48rpx;
  color: #EDE8DF;
  line-height: 1;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #EDE8DF;
}
.nav-placeholder {
  width: 60rpx;
}

/* 用户信息卡片 */
.profile-card {
  display: flex;
  align-items: center;
  margin: 32rpx 24rpx 24rpx;
  padding: 40rpx 32rpx;
  background: rgba(26, 48, 74, 0.6);
  border-radius: 20rpx;
  border: 1rpx solid rgba(139, 163, 185, 0.12);
}
.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  background: rgba(139, 163, 185, 0.15);
  flex-shrink: 0;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
}
.avatar-default {
  background: rgba(245, 200, 105, 0.15);
  border: 2rpx solid rgba(245, 200, 105, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 60rpx;
}
.avatar-letter {
  font-size: 48rpx;
  font-weight: 600;
  color: #F5C869;
}
.profile-info {
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
}
.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #EDE8DF;
  margin-bottom: 8rpx;
}
.profile-id {
  font-size: 24rpx;
  color: #8BA3B9;
  font-family: monospace;
  margin-bottom: 6rpx;
}
.profile-meta {
  font-size: 22rpx;
  color: #6B8BA5;
}

/* 表单卡片 */
.section-card {
  margin: 0 24rpx 24rpx;
  padding: 24rpx 28rpx;
  background: rgba(26, 48, 74, 0.5);
  border-radius: 16rpx;
  border: 1rpx solid rgba(139, 163, 185, 0.1);
}
.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(139, 163, 185, 0.08);
}
.form-label {
  font-size: 28rpx;
  color: #8BA3B9;
  width: 120rpx;
  flex-shrink: 0;
}
.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #EDE8DF;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 16rpx;
  background: rgba(13, 27, 42, 0.5);
  border-radius: 10rpx;
  margin-left: 16rpx;
}
.form-action {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}
.save-btn {
  background: #F5C869;
  color: #0D1B2A;
  font-size: 28rpx;
  font-weight: 600;
  padding: 14rpx 36rpx;
  border-radius: 12rpx;
  text-align: center;
}

/* 退出登录 */
.logout-section {
  margin: 48rpx 24rpx 0;
}
.logout-btn {
  background: rgba(232, 132, 107, 0.12);
  border: 1rpx solid rgba(232, 132, 107, 0.25);
  color: #E8846B;
  font-size: 30rpx;
  padding: 22rpx 0;
  border-radius: 14rpx;
  text-align: center;
}
