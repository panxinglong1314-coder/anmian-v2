.privacy-container {
  padding: 32rpx;
  background-color: #0D1B2A;
  min-height: 100vh;
  color: #E0E8F0;
}

.section {
  margin-bottom: 48rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #F5C869;
  margin-bottom: 24rpx;
  text-align: center;
}

.subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #8BA3B9;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.p {
  font-size: 28rpx;
  line-height: 1.8;
  color: #C5D4E8;
  margin-bottom: 12rpx;
}

.footer {
  margin-top: 64rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #1B3A5A;
  text-align: center;
}

.update-time {
  font-size: 24rpx;
  color: #5A7A9A;
}
