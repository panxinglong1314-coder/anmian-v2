/* pages/train/train.wxss */
/* Tab 2: 睡前训练 - 毛玻璃样式 */

.page {
  min-height: 100vh;
  background: #0D1B2A;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部毛玻璃标题栏 ===== */
.train-header {
  padding: 24rpx 32rpx 20rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: rgba(13, 27, 42, 0.85);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #F0F4F8;
}

.header-subtitle {
  font-size: 26rpx;
  color: #8BA3B9;
}

/* ===== 训练列表 ===== */
.train-list {
  flex: 1;
  padding: 24rpx 24rpx;
  overflow-y: auto;
}

/* ===== 毛玻璃训练卡片 ===== */
.train-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.train-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.04) 0%,
    transparent 60%
  );
  pointer-events: none;
}

.train-card:active {
  transform: scale(0.98);
}

/* 卡片边缘光晕 */
.card-glow {
  position: absolute;
  top: 0;
  right: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  filter: blur(30rpx);
  opacity: 0.35;
  pointer-events: none;
}

.card-glow-green {
  background: #7EC8A3;
}

.card-glow-blue {
  background: #6B9FD4;
}

.card-glow-gold {
  background: #F5C869;
}

.card-glow-coral {
  background: #E8846B;
}

/* 卡片图标 */
.card-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 0 8rpx rgba(255, 255, 255, 0.15));
}

/* 卡片内容 */
.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #F0F4F8;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #8BA3B9;
  line-height: 1.5;
  margin-bottom: 14rpx;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.meta-tag {
  font-size: 22rpx;
  color: #8BA3B9;
  background: rgba(36, 52, 71, 0.6);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

/* 卡片箭头 */
.card-arrow {
  font-size: 40rpx;
  color: rgba(139, 163, 185, 0.5);
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ===== 训练弹窗浮层 ===== */
.train-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(13, 27, 42, 0.75);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.train-modal {
  width: 90%;
  max-width: 640rpx;
  min-height: 600rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* 关闭按钮 */
.modal-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8BA3B9;
  background: rgba(36, 52, 71, 0.6);
  backdrop-filter: blur(8rpx);
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  z-index: 10;
}

.modal-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

/* ===== 呼吸引导 ===== */
.breathing-circle-container {
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.breathing-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(126, 200, 163, 0.4) 0%,
    rgba(126, 200, 163, 0.15) 100%
  );
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 3rpx solid rgba(126, 200, 163, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:
    0 0 50rpx rgba(126, 200, 163, 0.35),
    inset 0 0 30rpx rgba(126, 200, 163, 0.15);
}

.circle-inhale {
  transform: scale(1.35);
  background: radial-gradient(circle, rgba(126, 200, 163, 0.55) 0%, rgba(126, 200, 163, 0.25) 100%);
  border-color: rgba(126, 200, 163, 0.75);
  box-shadow: 0 0 70rpx rgba(126, 200, 163, 0.5), inset 0 0 40rpx rgba(126, 200, 163, 0.2);
}

.circle-hold {
  transform: scale(1.35);
  background: radial-gradient(circle, rgba(107, 159, 212, 0.55) 0%, rgba(107, 159, 212, 0.25) 100%);
  border-color: rgba(107, 159, 212, 0.75);
  box-shadow: 0 0 70rpx rgba(107, 159, 212, 0.45), inset 0 0 40rpx rgba(107, 159, 212, 0.2);
}

.circle-exhale {
  transform: scale(1);
  background: radial-gradient(circle, rgba(126, 200, 163, 0.3) 0%, rgba(126, 200, 163, 0.1) 100%);
  border-color: rgba(126, 200, 163, 0.4);
  box-shadow: 0 0 30rpx rgba(126, 200, 163, 0.2), inset 0 0 20rpx rgba(126, 200, 163, 0.1);
}

.circle-phase {
  font-size: 32rpx;
  color: #F0F4F8;
  text-align: center;
  text-shadow: 0 0 12rpx rgba(255, 255, 255, 0.3);
}

.breathing-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.breathing-cycle {
  font-size: 28rpx;
  color: #8BA3B9;
}

.breathing-tip {
  font-size: 26rpx;
  color: #7EC8A3;
  text-shadow: 0 0 8rpx rgba(126, 200, 163, 0.3);
}

/* ===== 进度条 ===== */
.progress-wrap {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}

.progress-bar {
  height: 8rpx;
  background: rgba(36, 52, 71, 0.8);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(126, 200, 163, 0.85) 0%, rgba(126, 200, 163, 0.5) 100%);
  border-radius: 4rpx;
  transition: width 1s linear;
  box-shadow: 0 0 8rpx rgba(126, 200, 163, 0.4);
}

/* ===== 通用训练 ===== */
.train-visual {
  font-size: 80rpx;
  filter: drop-shadow(0 0 16rpx rgba(255, 255, 255, 0.1));
}

.train-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  text-align: center;
}

.train-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #F0F4F8;
}

.train-desc {
  font-size: 26rpx;
  color: #8BA3B9;
  line-height: 1.6;
  max-width: 400rpx;
}

.train-timer {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.timer-display {
  font-size: 56rpx;
  font-weight: 300;
  color: #F0F4F8;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 16rpx rgba(245, 200, 105, 0.25);
}

.timer-total {
  font-size: 28rpx;
  color: #8BA3B9;
}

.train-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.train-actions .glass-btn,
.train-actions .glass-btn-primary {
  flex: 1;
  text-align: center;
  padding: 24rpx;
}

/* ===== 白噪音 ===== */
.noise-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 120rpx;
}

.noise-wave {
  width: 6rpx;
  border-radius: 3rpx;
  background: linear-gradient(to top, rgba(126, 200, 163, 0.8), rgba(126, 200, 163, 0.1));
  animation: wave 1.2s ease-in-out infinite;
}

.noise-wave-1 { height: 60rpx; animation-delay: 0s; }
.noise-wave-2 { height: 100rpx; animation-delay: 0.2s; }
.noise-wave-3 { height: 70rpx; animation-delay: 0.4s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); opacity: 0.4; }
  50% { transform: scaleY(1.2); opacity: 1; }
}

.noise-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.noise-title {
  font-size: 40rpx;
}

.noise-subtitle {
  font-size: 26rpx;
  color: #8BA3B9;
}

.noise-controls {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.volume-wrap {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.volume-label {
  font-size: 26rpx;
  color: #8BA3B9;
  flex-shrink: 0;
}

.volume-slider {
  flex: 1;
}

.glass-btn-active {
  background: rgba(126, 200, 163, 0.25);
  border-color: rgba(126, 200, 163, 0.35);
  color: #7EC8A3;
}

/* 开始按钮 */
.btn-start {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  border-radius: 24rpx;
}
