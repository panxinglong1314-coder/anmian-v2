/* pages/record/record.wxss - 方案B精简版 */

/* 页面根容器 */
.page {
  min-height: 100vh;
  background: #0D1B2A;
  display: flex;
  flex-direction: column;
}

/* 顶部标题栏 */
.record-header {
  padding: 20rpx 24rpx 16rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(13,27,42,0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-title { font-size: 32rpx; font-weight: 600; color: #EDE8DF; flex: 1; text-align: center; }
.header-user {
  display: flex;
  align-items: center;
  min-width: 120rpx;
}
.header-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(139, 163, 185, 0.15);
  flex-shrink: 0;
}
.header-avatar-default {
  background: rgba(245, 200, 105, 0.15);
  border: 1rpx solid rgba(245, 200, 105, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-avatar-letter {
  font-size: 24rpx;
  font-weight: 600;
  color: #F5C869;
}
.header-nickname {
  font-size: 24rpx;
  color: #8BA3B9;
  margin-left: 10rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.share-btn {
  display: flex; align-items: center; gap: 8rpx;
  padding: 10rpx 18rpx; border-radius: 999rpx;
  background: rgba(245,200,105,0.12);
  border: 1rpx solid rgba(245,200,105,0.2);
}
.share-icon { font-size: 24rpx; color: #F5C869; }
.share-text { font-size: 22rpx; color: #F5C869; }

/* 可滚动内容区 */
.record-content {
  flex: 1; padding: 24rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  overflow-y: auto; box-sizing: border-box; width: 100%;
}

/* ===== 区块1：三指标卡片（融入洞察+担忧箱） ===== */
.stats-section { padding-bottom: 16rpx; }
.stats-section .stats-row { display: flex; gap: 12rpx; margin: 0; }
.stat-card {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 20rpx 8rpx; border-radius: 20rpx;
  background: rgba(36,52,71,0.55); border: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(12rpx); box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.2);
  box-sizing: border-box; min-width: 0;
}
.stat-value { font-size: 48rpx; font-weight: 700; color: #EDE8DF; line-height: 1; }
.stat-unit, .stat-label { font-size: 20rpx; color: #8BA3B9; margin-top: 4rpx; }
.stat-label { font-size: 22rpx; }
.glow-gold { color: #F5C869; text-shadow: 0 0 16rpx rgba(245,200,105,0.4); }
.glow-green { color: #7EC8A3; text-shadow: 0 0 16rpx rgba(126,200,163,0.4); }

/* 洞察一行 */
.insight-line {
  background: rgba(36,52,71,0.5); border-radius: 16rpx;
  padding: 16rpx 20rpx; margin: 0 0 16rpx 0;
  font-size: 24rpx; color: #8BA3B9; line-height: 1.5;
  border-left: 4rpx solid rgba(245,200,105,0.4); display: flex; align-items: center; gap: 10rpx;
}
/* 融入卡片底部的轻量样式 */
.stats-section .insight-line.inset {
  background: transparent; border-radius: 0; border-left: none;
  margin: 16rpx 0 0 0; padding: 14rpx 4rpx 0 4rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.insight-label { font-size: 18rpx; color: #F5C869; border: 1rpx solid rgba(245,200,105,0.3); border-radius: 6rpx; padding: 2rpx 8rpx; flex-shrink: 0; }

/* 担忧箱入口 */
.worry-entry {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 20rpx; margin: 0 0 16rpx 0;
  background: rgba(245,200,105,0.08); border-radius: 16rpx;
  border: 1rpx solid rgba(245,200,105,0.15);
}
/* 融入卡片底部的轻量样式 */
.stats-section .worry-entry.inset {
  background: transparent; border-radius: 0; border: none;
  margin: 0; padding: 10rpx 4rpx 0 4rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.worry-entry-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: #F5C869; flex-shrink: 0; }
.worry-entry-dot.dot-empty { background: rgba(139,163,185,0.4); }
.worry-entry-text { flex: 1; font-size: 24rpx; color: #8BA3B9; }
.worry-entry-arrow { font-size: 28rpx; color: rgba(245,200,105,0.4); flex-shrink: 0; }

/* 区块卡片 */
.section-card {
  padding: 24rpx; margin: 0 0 16rpx 0; border-radius: 20rpx;
  background: rgba(36,52,71,0.5); border: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(12rpx); box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.15);
  box-sizing: border-box;
}
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 500; color: #EDE8DF; }
.section-period { font-size: 22rpx; color: #8BA3B9; }
.section-period-link { color: #F5C869; }

/* phase 颜色 */
.phase-learning .restriction-card,
.phase-learning { border-left-color: #5B9BD5; }
.phase-learning .section-period { color: #5B9BD5; }
.phase-stable .restriction-card,
.phase-stable { border-left-color: #7EC8A3; }
.phase-stable .section-period { color: #7EC8A3; }
.phase-optimizing .restriction-card,
.phase-optimizing { border-left-color: #F5C869; }
.phase-optimizing .section-period { color: #F5C869; }
.phase-restricting .restriction-card,
.phase-restricting { border-left-color: #E8846B; }
.phase-restricting .section-period { color: #E8846B; }

/* ===== 睡眠限制建议 ===== */
.restriction-card { border-left: 6rpx solid #F5C869; }
.restriction-body { padding: 20rpx 0 0; }
.restriction-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.restriction-item {
  flex: 1; background: rgba(139,163,185,0.08); border-radius: 16rpx;
  padding: 20rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.restriction-recommended { background: rgba(245,200,105,0.12); }
.restriction-label { font-size: 24rpx; color: #8BA3B9; }
.restriction-value { font-size: 30rpx; font-weight: 600; color: #EDE8DF; }
.restriction-sub { font-size: 24rpx; color: #F5C869; }
.restriction-arrow { font-size: 36rpx; color: #8BA3B9; font-weight: 600; flex-shrink: 0; }
.restriction-message { font-size: 26rpx; color: #EDE8DF; line-height: 1.6; margin-bottom: 16rpx; }
.restriction-se { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; padding: 12rpx 16rpx; background: rgba(139,163,185,0.06); border-radius: 12rpx; }
.restriction-se-label { font-size: 24rpx; color: #8BA3B9; }
.restriction-se-value { font-size: 32rpx; font-weight: 700; }
.restriction-se-hint { font-size: 24rpx; color: #E8846B; }
.restriction-action { display: flex; justify-content: flex-end; margin-top: 16rpx; }
.restriction-btn {
  background: linear-gradient(135deg, #F5C869 0%, #E8B84A 100%);
  color: #0D1B2A; font-size: 28rpx; font-weight: 600;
  padding: 18rpx 36rpx; border-radius: 32rpx;
}

/* 睡眠限制建议 - 默认金色 */
.restriction-card { border-left: 6rpx solid #F5C869; }

/* 睡眠计划打卡进度 */
.plan-progress { margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.06); }
.plan-label { font-size: 26rpx; color: #EDE8DF; margin-bottom: 12rpx; display: block; }
.plan-bar { height: 8rpx; background: rgba(36,52,71,0.8); border-radius: 4rpx; overflow: hidden; }
.plan-fill { height: 100%; background: linear-gradient(90deg, #F5C869, #E8B84A); border-radius: 4rpx; transition: width 0.4s ease; min-width: 4rpx; }

/* ===== 本周睡眠柱图 ===== */
.sleep-bars { display: flex; align-items: flex-end; gap: 12rpx; height: 140rpx; margin-top: 16rpx; }
.sleep-bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 12rpx; height: 100%; min-width: 0; }
.sleep-bar-bg { flex: 1; width: 100%; background: rgba(36,52,71,0.8); border-radius: 10rpx; overflow: hidden; display: flex; align-items: flex-end; }
.sleep-bar { width: 100%; border-radius: 10rpx 10rpx 0 0; }
.sleep-bar-good { background: linear-gradient(to top, rgba(126,200,163,0.8),rgba(126,200,163,0.3)); }
.sleep-bar-fair { background: linear-gradient(to top, rgba(245,200,105,0.8),rgba(245,200,105,0.3)); }
.sleep-bar-poor { background: linear-gradient(to top, rgba(232,132,107,0.8),rgba(232,132,107,0.3)); }
.sleep-bar-day { font-size: 24rpx; color: #8BA3B9; }

/* ===== 报告弹窗 ===== */
.report-overlay {
  position: fixed; inset: 0;
  background: rgba(13,27,42,0.8); backdrop-filter: blur(20rpx);
  display: flex; align-items: flex-end; z-index: 300;
}
.report-sheet {
  width: 100%; max-height: 85vh;
  background: linear-gradient(180deg,rgba(36,52,71,0.98),rgba(27,40,56,0.99));
  border-radius: 40rpx 40rpx 0 0;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  display: flex; flex-direction: column;
}
.sheet-handle { width: 60rpx; height: 6rpx; background: rgba(255,255,255,0.2); border-radius: 3rpx; margin: 20rpx auto; }
.sheet-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 40rpx 20rpx;
  padding-right: calc(40rpx + env(safe-area-inset-right));
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.sheet-title { font-size: 36rpx; font-weight: 600; color: #EDE8DF; }
.sheet-close {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08); color: #8BA3B9;
  display: flex; align-items: center; justify-content: center; font-size: 32rpx;
}
.sheet-content {
  flex: 1; padding: 32rpx 40rpx;
  padding-right: calc(40rpx + env(safe-area-inset-right));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

/* 报告区块 */
.report-section { margin-bottom: 40rpx; }
.report-section-title { font-size: 30rpx; font-weight: 600; color: #EDE8DF; margin-bottom: 24rpx; }

/* SE大圆环 */
.se-big-display { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; }
.se-circle {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  border: 10rpx solid; display: flex; align-items: center; justify-content: center; position: relative;
}
.se-circle-value { font-size: 64rpx; font-weight: 300; color: #EDE8DF; }
.se-circle-unit { font-size: 28rpx; color: #8BA3B9; position: absolute; bottom: 56rpx; }
.se-circle-label { font-size: 28rpx; color: #8BA3B9; margin-top: 24rpx; }

/* KPI行 */
.kpi-row { display: flex; gap: 20rpx; }
.kpi {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 28rpx 20rpx; background: rgba(255,255,255,0.05); border-radius: 20rpx;
}
.kpi-val { font-size: 40rpx; font-weight: 700; color: #EDE8DF; margin-bottom: 6rpx; }
.kpi-lbl { font-size: 22rpx; color: #8BA3B9; }

/* SE趋势图 */
.se-trend-chart { display: flex; align-items: flex-end; gap: 16rpx; height: 180rpx; padding: 24rpx; }
.se-trend-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.se-trend-bar-bg { flex: 1; width: 100%; background: rgba(36,52,71,0.6); border-radius: 8rpx; overflow: hidden; display: flex; align-items: flex-end; }
.se-trend-bar { width: 100%; border-radius: 8rpx; }
.se-good { background: linear-gradient(to top, rgba(126,200,163,0.9),rgba(126,200,163,0.4)); }
.se-fair { background: linear-gradient(to top, rgba(245,200,105,0.9),rgba(245,200,105,0.4)); }
.se-poor { background: linear-gradient(to top, rgba(232,132,107,0.9),rgba(232,132,107,0.4)); }
.se-trend-day { font-size: 22rpx; color: #8BA3B9; }

/* 建议文字 */
.rec-text { font-size: 26rpx; color: #8BA3B9; line-height: 1.6; }

/* 空状态 */
.empty-detail { font-size: 24rpx; color: #8BA3B9; text-align: center; padding: 40rpx 0; }

/* 加载中 */
.loading-mask {
  position: fixed; inset: 0; background: rgba(13,27,42,0.85);
  display: flex; align-items: center; justify-content: center; z-index: 999;
}
.loading-text { color: #8BA3B9; font-size: 28rpx; }


