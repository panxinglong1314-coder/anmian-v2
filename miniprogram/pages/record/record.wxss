/* pages/record/record.wxss — V2.1 精简版（功能完整）*/

/* 页面根容器 */
.page {
  min-height: 100vh;
  background: #0D1B2A;
  display: flex;
  flex-direction: column;
}

/* 顶部标题栏 */
.record-header {
  padding: 20rpx 24rpx 16rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(13,27,42,0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-title { font-size: 32rpx; font-weight: 600; color: #EDE8DF; flex: 1; text-align: center; }
.header-user {
  display: flex;
  align-items: center;
  min-width: 120rpx;
}
.header-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(139, 163, 185, 0.15);
  flex-shrink: 0;
}
.header-avatar-default {
  background: rgba(245, 200, 105, 0.15);
  border: 1rpx solid rgba(245, 200, 105, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-avatar-letter {
  font-size: 24rpx;
  font-weight: 600;
  color: #F5C869;
}
.header-nickname {
  font-size: 24rpx;
  color: #8BA3B9;
  margin-left: 10rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.share-btn {
  display: flex; align-items: center; gap: 8rpx;
  padding: 10rpx 18rpx; border-radius: 999rpx;
  background: rgba(245,200,105,0.12);
  border: 1rpx solid rgba(245,200,105,0.2);
}
.share-icon { font-size: 24rpx; color: #F5C869; }
.share-text { font-size: 22rpx; color: #F5C869; }

/* 可滚动内容区 */
.record-content {
  flex: 1; padding: 24rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  overflow-y: auto; box-sizing: border-box; width: 100%;
}

/* ================================================
   区块1：三指标横排
   ================================================ */
.stats-section {
  padding: 0 0 12rpx 0;
}

.stats-row {
  display: flex;
  gap: 12rpx;
  margin: 0;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(36,52,71,0.55);
  border: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
  min-width: 0;
}

/* 数字：统一 40rpx，不加 glow */
.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #EDE8DF;
  line-height: 1;
}
.stat-unit {
  font-size: 20rpx;
  color: #8BA3B9;
  margin-top: 4rpx;
}
.stat-label {
  font-size: 22rpx;
  color: #8BA3B9;
  margin-top: 4rpx;
}

/* 只在连续使用上用金色，作为唯一主强调色 */
.stat-card.gold .stat-value {
  color: #F5C869;
}
.stat-card.green .stat-value {
  color: #7EC8A3;
}

/* ================================================
   区块2：洞察文字行（轻量，无边框无背景）
   ================================================ */
.insight-row {
  padding: 0;
  margin: 10rpx 0 0 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.insight-text {
  font-size: 24rpx;
  color: #8BA3B9;
  line-height: 1;
  flex: 1;
}
.insight-prefix {
  font-size: 24rpx;
  color: #F5C869;
  flex-shrink: 0;
  align-self: center;
  line-height: 1;
}

/* ================================================
   区块3：睡眠窗口建议（精简）
   ================================================ */
.section-card {
  padding: 24rpx;
  margin: 0 0 16rpx 0;
  border-radius: 20rpx;
  background: rgba(36,52,71,0.5);
  border: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #EDE8DF;
}
.section-period {
  font-size: 22rpx;
  color: #8BA3B9;
}
.section-period-link {
  color: #F5C869;
}

/* 睡眠限制卡片：边框与 section-card 统一，不额外突出 */
.restriction-card {
  border: 1rpx solid rgba(255,255,255,0.08);
}

/* Phase 仅保留文字颜色指示，边框不再变色 */
.phase-learning .section-period { color: #5B9BD5; }
.phase-stable .section-period { color: #7EC8A3; }
.phase-optimizing .section-period { color: #F5C869; }
.phase-restricting .section-period { color: #E8846B; }

.restriction-body {
  padding: 16rpx 0 0;
}

.restriction-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.restriction-item {
  flex: 1;
  background: rgba(139,163,185,0.08);
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.restriction-recommended {
  background: rgba(245,200,105,0.12);
}
.restriction-label {
  font-size: 22rpx;
  color: #8BA3B9;
}
.restriction-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #EDE8DF;
}
.restriction-sub {
  font-size: 22rpx;
  color: #8BA3B9;
}
.restriction-arrow {
  font-size: 32rpx;
  color: #8BA3B9;
  font-weight: 600;
  flex-shrink: 0;
}

/* 精简的 message 文字（次色，低调） */
.restriction-message {
  font-size: 24rpx;
  color: #8BA3B9;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.restriction-se {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(139,163,185,0.06);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.restriction-se-label {
  font-size: 22rpx;
  color: #8BA3B9;
}
.restriction-se-value {
  font-size: 28rpx;
  font-weight: 700;
}
.restriction-se-hint {
  font-size: 22rpx;
  color: #E8846B;
  flex: 1;
}
.restriction-action {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}
.restriction-btn {
  background: #F5C869;
  color: #0D1B2A;
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
}

/* ================================================
   区块4：本周睡眠柱图（加大）
   ================================================ */
.sleep-bars {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  height: 160rpx;
  margin-top: 16rpx;
}
.sleep-bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  height: 100%;
  min-width: 0;
}
.sleep-bar-bg {
  flex: 1;
  width: 100%;
  background: rgba(36,52,71,0.8);
  border-radius: 10rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}
.sleep-bar {
  width: 100%;
  border-radius: 10rpx 10rpx 0 0;
}
.sleep-bar-good {
  background: linear-gradient(to top, rgba(126,200,163,0.8),rgba(126,200,163,0.3));
}
.sleep-bar-fair {
  background: linear-gradient(to top, rgba(245,200,105,0.8),rgba(245,200,105,0.3));
}
.sleep-bar-poor {
  background: linear-gradient(to top, rgba(232,132,107,0.8),rgba(232,132,107,0.3));
}
.sleep-bar-empty {
  background: transparent;
}
.sleep-bar-day {
  font-size: 22rpx;
  color: #8BA3B9;
}

/* ================================================
   担忧箱入口（纯文字行，带左侧圆点）
   ================================================ */
.worry-entry {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0;
  margin: 0;
}
.worry-entry-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #F5C869;
  flex-shrink: 0;
  align-self: center;
  /* 中文字符的视觉中心比 line-box 几何中心偏下，圆点下移视觉居中 */
  transform: translateY(5rpx);
}
.worry-entry-dot.dot-empty {
  background: rgba(139,163,185,0.4);
}
.worry-entry-text {
  flex: 1;
  font-size: 24rpx;
  color: #8BA3B9;
  line-height: 1;
}
.worry-entry-text.has-unread {
  color: #EDE8DF;
}
.worry-entry-arrow {
  font-size: 24rpx;
  color: rgba(139,163,185,0.4);
  flex-shrink: 0;
  line-height: 1;
}

/* ================================================
   睡眠计划打卡进度
   ================================================ */
.plan-progress {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.plan-label {
  font-size: 24rpx;
  color: #8BA3B9;
  margin-bottom: 12rpx;
  display: block;
}
.plan-bar {
  height: 6rpx;
  background: rgba(36,52,71,0.8);
  border-radius: 3rpx;
  overflow: hidden;
}
.plan-fill {
  height: 100%;
  background: linear-gradient(90deg, #F5C869, #E8B84A);
  border-radius: 3rpx;
  transition: width 0.4s ease;
  min-width: 3rpx;
}

/* ================================================
   报告弹窗
   ================================================ */
.report-overlay {
  position: fixed; inset: 0;
  background: rgba(13,27,42,0.8);
  backdrop-filter: blur(20rpx);
  display: flex; align-items: flex-end; z-index: 300;
  padding: 0 env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
}
.report-sheet {
  width: 100%; max-height: 85vh;
  background: linear-gradient(180deg, rgba(36,52,71,0.92), rgba(27,40,56,0.95));
  border-radius: 40rpx 40rpx 0 0;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  display: flex; flex-direction: column;
}
.sheet-handle {
  width: 60rpx; height: 6rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 3rpx;
  margin: 20rpx auto;
}
.sheet-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 40rpx 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  flex-shrink: 0;
}
.sheet-title { font-size: 32rpx; font-weight: 600; color: #EDE8DF; letter-spacing: -0.4px; }
.sheet-close {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08); color: #8BA3B9;
  display: flex; align-items: center; justify-content: center; font-size: 28rpx;
  border: none;
}
.sheet-close:active { background: rgba(255,255,255,0.12); }
.sheet-content {
  flex: 1; padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  box-sizing: border-box;
}

/* 报告区块 */
.report-section { margin-bottom: 32rpx; }
.report-section-title { font-size: 20rpx; font-weight: 500; color: #8BA3B9; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 16rpx; }

/* SE大圆环 */
.se-big-display {
  display: flex; flex-direction: column; align-items: center;
  padding: 32rpx 0;
}
.se-circle {
  width: 180rpx; height: 180rpx; border-radius: 50%;
  border: 8rpx solid;
  display: flex; align-items: center; justify-content: center; position: relative;
}
.se-circle-value { font-size: 56rpx; font-weight: 300; color: #EDE8DF; letter-spacing: -1px; line-height: 1; }
.se-circle-unit { font-size: 24rpx; color: #8BA3B9; position: absolute; bottom: 44rpx; }
.se-circle-label { font-size: 26rpx; color: #8BA3B9; margin-top: 20rpx; font-weight: 400; }

/* KPI行 */
.kpi-row { display: flex; gap: 12rpx; }
.kpi {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 20rpx 12rpx;
  background: rgba(36,52,71,0.6); border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.kpi-val { font-size: 36rpx; font-weight: 700; color: #EDE8DF; margin-bottom: 4rpx; letter-spacing: -0.5px; }
.kpi-lbl { font-size: 20rpx; color: #8BA3B9; }

/* SE趋势图 */
.se-trend-chart {
  display: flex; align-items: flex-end; gap: 12rpx;
  height: 160rpx; padding: 0;
}
.se-trend-col {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; gap: 8rpx;
}
.se-trend-bar-bg {
  flex: 1; width: 100%;
  background: rgba(36,52,71,0.35);
  border-radius: 8rpx; overflow: hidden; display: flex; align-items: flex-end;
}
.se-trend-bar { width: 100%; border-radius: 8rpx; }
.se-good  { background: linear-gradient(to top, rgba(126,200,163,0.9),rgba(126,200,163,0.3)); }
.se-fair  { background: linear-gradient(to top, rgba(245,200,105,0.9),rgba(245,200,105,0.3)); }
.se-poor  { background: linear-gradient(to top, rgba(232,132,107,0.9),rgba(232,132,107,0.3)); }
.se-trend-day { font-size: 20rpx; color: #8BA3B9; }

/* 建议文字 */
.rec-text { font-size: 26rpx; color: #8BA3B9; line-height: 1.6; padding: 16rpx; background: rgba(36,52,71,0.4); border-radius: 12rpx; }

/* 空状态 */
.empty-detail { font-size: 26rpx; color: #8BA3B9; text-align: center; padding: 64rpx 0; }

/* 加载中 */
.loading-mask {
  position: fixed; inset: 0;
  background: rgba(13,27,42,0.85);
  display: flex; align-items: center; justify-content: center; z-index: 999;
}
.loading-text { color: #8BA3B9; font-size: 28rpx; }
/* ================================================
   晨间打卡提示条（7-12点未打卡时显示）
   ================================================ */
.morning-prompt {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(245,200,105,0.12), rgba(245,200,105,0.06));
  border: 1rpx solid rgba(245,200,105,0.2);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.morning-prompt-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}
.morning-prompt-text {
  flex: 1;
  font-size: 26rpx;
  color: #EDE8DF;
}
.morning-prompt-arrow {
  font-size: 32rpx;
  color: rgba(245,200,105,0.5);
  flex-shrink: 0;
}

/* ================================================
   晨间打卡弹窗
   ================================================ */
.morning-overlay {
  position: fixed;
  inset: 0;
  background: rgba(13,27,42,0.85);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 500;
}

.morning-card {
  width: 600rpx;
  background: linear-gradient(180deg, rgba(36,52,71,0.92), rgba(27,40,56,0.95));
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4);
  position: relative;
}

.morning-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  color: #8BA3B9;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.morning-progress {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.morning-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(139,163,185,0.3);
}

.morning-dot.active {
  background: #F5C869;
}

.morning-dot.done {
  background: rgba(126,200,163,0.8);
}

.morning-step-title {
  font-size: 28rpx;
  color: #8BA3B9;
  text-align: center;
  margin-bottom: 32rpx;
}

.morning-question {
  font-size: 32rpx;
  font-weight: 600;
  color: #EDE8DF;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.morning-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.morning-option {
  padding: 20rpx 24rpx;
  background: rgba(139,163,185,0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  font-size: 28rpx;
  color: #EDE8DF;
  text-align: center;
}

.morning-option:active {
  background: rgba(245,200,105,0.12);
  border-color: rgba(245,200,105,0.3);
}

/* 完成后状态 */
.morning-result-icon {
  font-size: 64rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.morning-result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #EDE8DF;
  text-align: center;
  margin-bottom: 32rpx;
}

.morning-result-row {
  display: flex;
  gap: 32rpx;
  justify-content: center;
  margin-bottom: 40rpx;
}

.morning-result-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.morning-result-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #F5C869;
}

.morning-result-label {
  font-size: 22rpx;
  color: #8BA3B9;
}

.morning-done-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #F5C869;
  color: #0D1B2A;
  /* 【2026-05-15】30→28rpx：与全局按钮字号档对齐（28 是主按钮标准） */
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
  text-align: center;
}

/* ============================================================
   睡眠效率详情 — 基于 Linear/open-design 设计系统
   Token: canvas=#010102 surface-1=#0f1011 surface-2=#141516 surface-3=#18191a hairline=#23252a
          ink=#f7f8f8 ink-muted=#d0d6e0 ink-subtle=#8a8f98 ink-tertiary=#62666d
          primary=#5e6ad2 on-primary=#ffffff primary-hover=#828fff primary-focus=#5e69d1
          semantic-success=#27a644
   圆角: xs=4rpx sm=6rpx md=12rpx lg=16rpx pill=9999rpx
   ============================================================ */

/* ---- Sheet 容器 ---- */
.report-sheet {
  width: 100%;
  max-height: 90vh;
  background: linear-gradient(180deg, rgba(36,52,71,0.92), rgba(27,40,56,0.95));
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  flex-direction: column;
}
.sheet-handle {
  width: 60rpx; height: 6rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 3rpx;
  margin: 16rpx auto;
  flex-shrink: 0;
}
.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  flex-shrink: 0;
}
.sheet-title {
  font-size: 32rpx; font-weight: 600; color: #f7f8f8; /* ink */
  letter-spacing: -0.4px;
}
.sheet-close {
  width: 60rpx; height: 60rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  color: #8BA3B9;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  border: none;
}
.sheet-close:active { background: rgba(255,255,255,0.12); }

/* ---- 报告区块 (通用容器) ---- */
.report-section {
  margin-bottom: 40rpx;
}
.report-section + .report-section {
  margin-top: 0;
}

/* ---- Section 标题 ---- */
.report-section-title {
  font-size: 20rpx;
  font-weight: 500;
  color: #8BA3B9;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

/* ---- SE 大圆环展示 ---- */
.se-big-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 32rpx;
}
.se-circle {
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  border: 8rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background: rgba(36,52,71,0.5);
}
.se-circle-value {
  font-size: 56rpx; font-weight: 300;
  color: #EDE8DF;
  letter-spacing: -1px;
  line-height: 1;
}
.se-circle-unit {
  font-size: 22rpx; color: #8BA3B9;
  position: absolute; bottom: 36rpx;
  margin-left: 2rpx;
}
.se-circle-label {
  font-size: 26rpx; color: #8BA3B9;
  margin-top: 20rpx;
  font-weight: 400;
}

/* ---- KPI 行: 3列 stats ---- */
.kpi-row {
  display: flex;
  gap: 12rpx;
}
.kpi {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: rgba(36,52,71,0.45);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.kpi-val {
  font-size: 36rpx; font-weight: 700;
  color: #EDE8DF;
  margin-bottom: 4rpx;
  letter-spacing: -0.5px;
}
.kpi-lbl {
  font-size: 20rpx; color: #8BA3B9;
}

/* ---- SE 趋势图 (柱状图) ---- */
.se-trend-chart {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 120rpx;
  padding: 8rpx 0;
}
.se-trend-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.se-trend-bar-bg {
  flex: 1; width: 100%;
  background: rgba(36,52,71,0.6);
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}
.se-trend-bar {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
}
.se-good  { background: linear-gradient(to top, rgba(126,200,163,0.9),rgba(126,200,163,0.3)); }
.se-fair  { background: linear-gradient(to top, rgba(245,200,105,0.9),rgba(245,200,105,0.3)); }
.se-poor  { background: linear-gradient(to top, rgba(232,132,107,0.9),rgba(232,132,107,0.3)); }
.se-trend-day {
  /* 【2026-05-15】18→22rpx：周历下方日期太小，弱视/弱光看不清 */
  font-size: 22rpx; color: #8BA3B9;
}

/* ---- SRT 区块 ---- */
.srt-section {
  background: rgba(36,52,71,0.75);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.srt-phase-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  letter-spacing: 0;
}

.srt-window-info {
  margin: 12rpx 0;
}

.srt-window-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.srt-window-row:last-child { border-bottom: none; }

.srt-window-row.highlight {
  background: rgba(245,200,105,0.1);
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-top: 6rpx;
  border-bottom: none;
}

.srt-window-label {
  color: #8BA3B9;
  font-size: 26rpx;
}
.srt-window-value {
  color: #EDE8DF;
  font-size: 28rpx;
  font-weight: 600;
}

.srt-tip {
  font-size: 22rpx;
  color: #8BA3B9;
  margin-top: 10rpx;
  line-height: 1.5;
}

/* 知眠 CTA: 金色渐变 */
.srt-apply-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #F5C869, #E8B84A);
  color: #0D1B2A;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  margin-top: 20rpx;
  text-align: center;
  border: none;
}
.srt-apply-btn:active { opacity: 0.85; }

/* ---- 每日建议列表 ---- */
.daily-tips-list { display: flex; flex-direction: column; gap: 8rpx; }
.srt-tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  background: rgba(36,52,71,0.4);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  font-size: 24rpx;
  color: #EDE8DF;
  line-height: 1.5;
}
.srt-tip-item-dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: #F5C869;
  flex-shrink: 0;
  margin-top: 8rpx;
}

/* ---- 建议文字 (非SRT) ---- */
.rec-text {
  font-size: 26rpx; color: #8BA3B9;
  line-height: 1.6;
  padding: 16rpx;
  background: rgba(36,52,71,0.4);
  border-radius: 12rpx;
}

/* ---- 空状态 ---- */
.empty-detail {
  font-size: 26rpx; color: #8BA3B9;
  text-align: center; padding: 64rpx 0;
}

/* ---- 加载状态 ---- */
.loading-mask {
  position: fixed; inset: 0;
  background: rgba(1,1,2,0.85);          /* canvas overlay */
  display: flex; align-items: center; justify-content: center; z-index: 999;
}
