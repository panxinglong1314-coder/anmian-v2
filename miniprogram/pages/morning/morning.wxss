/* pages/morning/morning.wxss - 早晨回访 Tab */

/* ================================================
   全局
   ================================================ */
.page {
  min-height: 100vh;
  background: #0D1B2A;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ================================================
   顶部问候区
   ================================================ */
.morning-header {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: calc(48rpx + env(safe-area-inset-top));
  padding-bottom: 24rpx;
  background: linear-gradient(180deg, rgba(245, 200, 105, 0.06) 0%, transparent 100%);
  position: relative;
}

.greeting {
  font-size: 52rpx;
  font-weight: 300;
  color: #F5C869;
  text-shadow: 0 0 20rpx rgba(245, 200, 105, 0.3);
  letter-spacing: 2rpx;
}

.date-text {
  font-size: 26rpx;
  color: rgba(139, 163, 185, 0.7);
  margin-top: 8rpx;
}

/* ================================================
   状态：不在回访时间
   ================================================ */
.state-not-time {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 48rpx 40rpx;
  position: relative;
}

.not-time-icon {
  font-size: 96rpx;
  filter: drop-shadow(0 0 20rpx rgba(245, 200, 105, 0.2));
}

.moon-glow {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 200, 105, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.not-time-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #F0F4F8;
}

.not-time-sub {
  font-size: 26rpx;
  color: #8BA3B9;
  text-align: center;
  line-height: 1.7;
  max-width: 480rpx;
}

/* ================================================
   状态：今日已完成
   ================================================ */
.state-completed {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 40rpx;
  gap: 28rpx;
  width: 100%;
}

.completed-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 40rpx;
  background: rgba(126, 200, 163, 0.1);
  border: 1rpx solid rgba(126, 200, 163, 0.25);
  border-radius: 16rpx;
}

.completed-icon {
  font-size: 48rpx;
}

.completed-label {
  font-size: 28rpx;
  color: #7EC8A3;
  font-weight: 500;
}

/* 迷你报告卡 */
.mini-report-card {
  width: 100%;
  background: rgba(36, 52, 71, 0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  padding: 28rpx 24rpx;
}

.mini-report-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.mini-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.mini-stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #F5C869;
}

.mini-stat-label {
  font-size: 20rpx;
  color: #8BA3B9;
}

.go-record-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 48rpx;
  background: rgba(36, 52, 71, 0.6);
  backdrop-filter: blur(16rpx);
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-top: 8rpx;
}

.go-record-btn text {
  font-size: 28rpx;
  color: #F0F4F8;
}

/* ================================================
   状态：问卷进行中
   ================================================ */
.state-questionnaire {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 32rpx;
  gap: 24rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

/* AI 语音气泡 */
.ai-bubble-container {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  align-self: flex-start;
  padding-top: 8rpx;
  max-width: 85%;
  animation: fadeInUp 0.35s ease;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.ai-avatar-small {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  filter: drop-shadow(0 0 8rpx rgba(245, 200, 105, 0.3));
}

.ai-bubble {
  background: rgba(36, 52, 71, 0.7);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-radius: 16rpx 16rpx 16rpx 4rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.ai-bubble text {
  font-size: 28rpx;
  color: #F0F4F8;
  line-height: 1.6;
}

.ai-speaking-indicator {
  display: flex;
  align-items: center;
}

.ai-wave-small {
  display: flex;
  align-items: center;
  gap: 3rpx;
  height: 16rpx;
}

.wave-dot {
  width: 5rpx;
  border-radius: 3rpx;
  background: #F5C869;
  animation: waveDot 1s ease-in-out infinite;
}

.wave-dot:nth-child(1) { height: 6rpx; animation-delay: 0s; }
.wave-dot:nth-child(2) { height: 10rpx; animation-delay: 0.15s; }
.wave-dot:nth-child(3) { height: 7rpx; animation-delay: 0.3s; }

@keyframes waveDot {
  0%, 100% { transform: scaleY(0.5); opacity: 0.4; }
  50% { transform: scaleY(1.2); opacity: 1; }
}

/* 进度条 */
.question-progress {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx;
}

.progress-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.progress-dot {
  width: 24rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: rgba(36, 52, 71, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.3s ease;
}

.progress-dot.active {
  background: linear-gradient(90deg, rgba(245, 200, 105, 0.8), rgba(245, 200, 105, 0.4));
  border-color: rgba(245, 200, 105, 0.3);
  width: 40rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #8BA3B9;
}

/* 问题卡片 */
.question-card {
  width: 100%;
  background: rgba(36, 52, 71, 0.55);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: fadeInUp 0.3s ease;
}

.question-text {
  font-size: 34rpx;
  font-weight: 500;
  color: #F0F4F8;
  line-height: 1.5;
  text-align: center;
}

/* 选项列表 - 横向 pill 风格 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(36, 52, 71, 0.5);
  backdrop-filter: blur(12rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  cursor: pointer;
  transition: all 0.22s ease;
}

.option-pill:active {
  transform: scale(0.97);
}

.option-pill.selected {
  background: rgba(245, 200, 105, 0.18);
  border-color: rgba(245, 200, 105, 0.45);
  box-shadow: 0 0 16rpx rgba(245, 200, 105, 0.15);
}

.option-label {
  font-size: 28rpx;
  color: #F0F4F8;
  font-weight: 400;
}

.option-pill.selected .option-label {
  color: #F5C869;
  font-weight: 500;
}

.option-desc {
  font-size: 22rpx;
  color: #8BA3B9;
}

/* TTS 进度 */
.tts-progress-bar {
  width: 100%;
  padding: 0 4rpx;
}

.tts-track {
  height: 4rpx;
  background: rgba(36, 52, 71, 0.8);
  border-radius: 2rpx;
  overflow: hidden;
}

.tts-fill {
  height: 100%;
  background: linear-gradient(90deg, #F5C869, rgba(245, 200, 105, 0.5));
  border-radius: 2rpx;
  transition: width 0.3s linear;
  box-shadow: 0 0 6rpx rgba(245, 200, 105, 0.4);
}

/* ================================================
   状态：睡眠报告
   ================================================ */
.state-report {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 32rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  gap: 20rpx;
}

.report-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding-top: 8rpx;
}

.report-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #F5C869;
  text-shadow: 0 0 12rpx rgba(245, 200, 105, 0.35);
}

.report-date {
  font-size: 24rpx;
  color: #8BA3B9;
}

/* SE 圆环仪表盘 */
.se-gauge-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.se-ring-outer {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(36, 52, 71, 0.2);
  box-shadow: 0 0 40rpx rgba(245, 200, 105, 0.1);
}

.se-ring-fill {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.se-ring-inner {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #0D1B2A;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  position: relative;
  z-index: 2;
  box-shadow: inset 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
}

.se-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #F5C869;
  text-shadow: 0 0 12rpx rgba(245, 200, 105, 0.5);
}

.se-label {
  font-size: 22rpx;
  color: #8BA3B9;
}

/* 睡眠数据卡片 */
.report-data-card {
  width: 100%;
  background: rgba(36, 52, 71, 0.65);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 28rpx 20rpx;
}

.data-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.data-icon {
  font-size: 32rpx;
}

.data-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #F0F4F8;
}

.data-label {
  font-size: 20rpx;
  color: #8BA3B9;
}

.data-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.07);
}

/* SOL 提示卡 */
.sol-tip-card {
  width: 100%;
  background: rgba(245, 200, 105, 0.07);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-radius: 14rpx;
  border: 1rpx solid rgba(245, 200, 105, 0.15);
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sol-tip-label {
  font-size: 22rpx;
  color: #F5C869;
  font-weight: 500;
}

.sol-tip-text {
  font-size: 24rpx;
  color: #8BA3B9;
  line-height: 1.6;
}

/* 报告操作区 */
.report-action {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  margin-top: 8rpx;
}

.btn-record {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 56rpx;
  background: linear-gradient(135deg, rgba(245, 200, 105, 0.3), rgba(245, 200, 105, 0.15));
  backdrop-filter: blur(16rpx);
  border-radius: 999rpx;
  border: 1rpx solid rgba(245, 200, 105, 0.35);
  box-shadow: 0 0 24rpx rgba(245, 200, 105, 0.2);
  cursor: pointer;
  transition: all 0.2s;
}

.btn-record text {
  font-size: 28rpx;
  color: #F5C869;
  font-weight: 500;
}

.btn-record:active {
  transform: scale(0.97);
}

.report-footer-hint {
  font-size: 22rpx;
  color: rgba(139, 163, 185, 0.45);
}
