<!-- pages/worries/worries.wxml -->
<view class="page">

  <view class="worries-header">
    <text class="header-title">担忧箱</text>
    <text wx:if="{{worryList.length > 0}}" class="header-action" bindtap="markAllRead">全部标记已读</text>
  </view>

  <scroll-view class="worries-content" scroll-y="true">

    <!-- 分类标签 -->
    <view class="filter-tabs" wx:if="{{worryList.length > 0}}">
      <text class="filter-tab {{filter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-filter="all">全部</text>
      <text class="filter-tab {{filter === 'vent' ? 'active' : ''}}" bindtap="setFilter" data-filter="vent">倾诉型</text>
      <text class="filter-tab {{filter === 'action' ? 'active' : ''}}" bindtap="setFilter" data-filter="action">行动型</text>
      <text class="filter-tab {{filter === 'ruminate' ? 'active' : ''}}" bindtap="setFilter" data-filter="ruminate">反刍型</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{worryList.length === 0 && !isLoading}}" class="empty-state">
      <text class="empty-title">暂无担忧记录</text>
      <text class="empty-desc">在「今晚聊聊」里说出你的担忧，我会帮你记下来</text>
    </view>

    <!-- 担忧列表 -->
    <view wx:for="{{filteredList}}" wx:key="id" class="worry-item {{item.reviewed ? 'reviewed' : ''}}">
      <view class="worry-main" bindtap="toggleExpand" data-index="{{index}}">
        <view class="worry-status">
          <view class="worry-dot {{item.reviewed ? 'dot-read' : 'dot-unread'}}"></view>
        </view>
        <view class="worry-body">
          <text class="worry-text">{{item.text}}</text>
          <view class="worry-meta">
            <text class="worry-type">{{item.type === 'vent' ? '倾诉型' : item.type === 'action' ? '行动型' : '反刍型'}}</text>
            <text class="worry-date">{{item.dateStr}}</text>
          </view>
        </view>
        <text class="worry-arrow">{{item.expanded ? '▾' : '▸'}}</text>
      </view>

      <view wx:if="{{item.expanded}}" class="worry-actions">
        <text class="worry-btn primary" bindtap="markRead" data-id="{{item.id}}">{{item.reviewed ? '标记未读' : '标记已读'}}</text>
        <text class="worry-btn" bindtap="revisit" data-text="{{item.text}}">再说几句</text>
      </view>
    </view>

    <!-- CBT 提示 -->
    <view wx:if="{{worryList.length > 0}}" class="cbt-tip">
      <text class="cbt-tip-text">担忧写下后，明天再看，会发现很多担忧其实不会发生</text>
    </view>

  </scroll-view>
</view>
