/* pages/worries/worries.wxss */
.page {
  min-height: 100vh;
  background: #0D1B2A;
  display: flex;
  flex-direction: column;
}

.worries-header {
  padding: 20rpx 24rpx 16rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(13,27,42,0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-title { font-size: 32rpx; font-weight: 600; color: #EDE8DF; }
.header-action { font-size: 24rpx; color: #F5C869; }

.worries-content {
  flex: 1; padding: 24rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

/* 分类标签 */
.filter-tabs {
  display: flex; gap: 16rpx; margin-bottom: 24rpx;
  overflow-x: auto; white-space: nowrap;
}
.filter-tab {
  font-size: 24rpx; color: #8BA3B9; padding: 8rpx 20rpx;
  border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,0.08);
  flex-shrink: 0;
}
.filter-tab.active {
  color: #F5C869; border-color: rgba(245,200,105,0.3);
  background: rgba(245,200,105,0.08);
}

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 40rpx; text-align: center;
}
.empty-title { font-size: 32rpx; font-weight: 600; color: #EDE8DF; margin-bottom: 16rpx; }
.empty-desc { font-size: 26rpx; color: #8BA3B9; line-height: 1.6; }

/* 担忧项 */
.worry-item {
  background: rgba(36,52,71,0.5); border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  margin-bottom: 16rpx; overflow: hidden;
}
.worry-item.reviewed { opacity: 0.6; }
.worry-main {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 20rpx;
}
.worry-status { padding-top: 6rpx; flex-shrink: 0; }
.worry-dot { width: 8rpx; height: 8rpx; border-radius: 50%; }
.dot-unread { background: #F5C869; }
.dot-read { background: rgba(139,163,185,0.4); }
.worry-body { flex: 1; min-width: 0; }
.worry-text { font-size: 28rpx; color: #EDE8DF; line-height: 1.5; display: block; margin-bottom: 8rpx; }
.worry-meta { display: flex; gap: 16rpx; }
.worry-type { font-size: 20rpx; color: #5B9BD5; }
.worry-date { font-size: 20rpx; color: #8BA3B9; }
.worry-arrow { font-size: 24rpx; color: #8BA3B9; flex-shrink: 0; padding-top: 4rpx; }

/* 展开操作 */
.worry-actions {
  display: flex; gap: 16rpx; padding: 0 20rpx 20rpx 44rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
  padding-top: 16rpx;
}
.worry-btn {
  font-size: 24rpx; color: #8BA3B9; padding: 10rpx 24rpx;
  border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,0.1);
}
.worry-btn.primary { color: #F5C869; border-color: rgba(245,200,105,0.25); }

/* CBT 提示 */
.cbt-tip {
  margin-top: 24rpx; padding: 20rpx;
  background: rgba(126,200,163,0.08); border-radius: 16rpx;
  border: 1rpx solid rgba(126,200,163,0.15);
}
.cbt-tip-text { font-size: 24rpx; color: #7EC8A3; line-height: 1.5; }
