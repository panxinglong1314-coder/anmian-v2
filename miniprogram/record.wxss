/* pages/record/record.wxss - 清爽版 */

/* 页面根容器 */
.page { 
  min-height: 100vh;
  background: #0D1B2A; 
  display: flex; 
  flex-direction: column;
  padding-bottom: 120rpx;
}

/* ========== 顶部标题栏 ========== */
.record-header {
  padding: 20rpx 24rpx 16rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: rgba(13,27,42,0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  display: flex; 
  justify-content: space-between; 
  align-items: center;
}

.header-title { 
  font-size: 32rpx; 
  font-weight: 600; 
  color: #F0F4F8; 
}

.share-btn { 
  display: flex; 
  align-items: center; 
  gap: 8rpx; 
  padding: 10rpx 18rpx; 
  border-radius: 999rpx; 
  background: rgba(245,200,105,0.12); 
  border: 1rpx solid rgba(245,200,105,0.2); 
}

.share-icon { 
  font-size: 24rpx; 
}

.share-text { 
  font-size: 22rpx; 
  color: #F5C869; 
}

/* ========== 可滚动内容区 ========== */
.record-content { 
  flex: 1; 
  padding: 24rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  overflow-y: auto; 
  scroll-y: true;
  box-sizing: border-box;
  width: 100%;
}

/* 焦虑摘要卡（顶部直接显示） */
.insight-summary-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  margin: 0 0 20rpx 0;
  border-radius: 16rpx;
  background: rgba(107,159,212,0.08);
  border: 1rpx solid rgba(107,159,212,0.12);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
}
.insight-summary-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}
.insight-summary-text {
  flex: 1;
  font-size: 24rpx;
  color: #F0F4F8;
  line-height: 1.5;
}
.insight-summary-arrow {
  font-size: 28rpx;
  color: rgba(107,159,212,0.5);
  flex-shrink: 0;
}

/* ========== 统计卡片行 ========== */
.stats-row { 
  display: flex; 
  gap: 12rpx; 
  margin: 0 0 24rpx 0;
}

.stat-card { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 20rpx 8rpx; 
  border-radius: 20rpx; 
  background: rgba(36,52,71,0.55); 
  border: 1rpx solid rgba(255,255,255,0.08); 
  backdrop-filter: blur(12rpx);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.2);
  box-sizing: border-box;
  min-width: 0;
}

.stat-value { 
  font-size: 48rpx; 
  font-weight: 700; 
  color: #F0F4F8; 
  line-height: 1; 
}

.stat-unit { 
  font-size: 20rpx; 
  color: #8BA3B9; 
  margin-top: 4rpx; 
}

.stat-label { 
  font-size: 22rpx; 
  color: #8BA3B9; 
  margin-top: 6rpx; 
}

.glow-gold { 
  color: #F5C869; 
}

.glow-green { 
  color: #7EC8A3; 
}

/* ========== 区块卡片 ========== */
.section-card { 
  padding: 24rpx; 
  margin: 0 0 16rpx 0;
  border-radius: 20rpx; 
  background: rgba(36,52,71,0.5); 
  border: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(12rpx);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.15);
  box-sizing: border-box;
}

.section-header { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  margin-bottom: 20rpx; 
}

.section-title { 
  font-size: 28rpx; 
  font-weight: 500; 
  color: #F0F4F8; 
}

.section-period { 
  font-size: 22rpx; 
  color: #8BA3B9; 
}

/* ========== 睡眠效率仪表盘 ========== */
.dashboard-card { 
  cursor: pointer; 
}

.section-header-right { 
  display: flex; 
  align-items: center; 
  gap: 12rpx; 
}

.dashboard-emoji { 
  font-size: 32rpx; 
}

.dashboard-preview { 
  display: flex; 
  flex-direction: column; 
  gap: 16rpx; 
}

.dashboard-main-stat { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 16rpx 0; 
}

.dashboard-se-value { 
  font-size: 72rpx; 
  font-weight: 700; 
  line-height: 1; 
}

.dashboard-se-unit { 
  font-size: 32rpx; 
  font-weight: 400; 
  margin-left: 4rpx; 
}

.dashboard-se-label { 
  font-size: 24rpx; 
  color: #8BA3B9; 
  margin-top: 8rpx; 
}

.dashboard-sub-stats { 
  display: flex; 
  justify-content: space-around; 
  padding: 16rpx 0; 
  border-top: 1rpx solid rgba(255,255,255,0.06); 
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  width: 100%;
  box-sizing: border-box; 
}

.dashboard-sub-stat { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  gap: 8rpx; 
}

.sub-stat-value { 
  font-size: 32rpx; 
  font-weight: 600; 
  color: #F0F4F8; 
}

.sub-stat-label { 
  font-size: 22rpx; 
  color: #8BA3B9; 
}

.dashboard-message { 
  font-size: 28rpx; 
  color: #F0F4F8; 
  text-align: center; 
  padding: 20rpx; 
  background: rgba(126,200,163,0.08); 
  border-radius: 12rpx; 
}

.dashboard-empty { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 48rpx 32rpx; 
  gap: 16rpx; 
}

.dashboard-empty-icon { 
  font-size: 64rpx; 
}

.dashboard-empty-text { 
  font-size: 32rpx; 
  color: #F0F4F8; 
  font-weight: 500; 
}

.dashboard-empty-hint { 
  font-size: 26rpx; 
  color: #8BA3B9; 
}

/* ========== 本周睡眠 ========== */

/* 早安评分 */
.sleep-rating-card { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  gap: 16rpx; 
  padding: 32rpx; 
  margin-bottom: 24rpx; 
  background: rgba(107,159,212,0.1); 
  border-radius: 16rpx; 
  border: 1rpx solid rgba(107,159,212,0.15); 
}

.rating-title { 
  font-size: 30rpx; 
  color: #F0F4F8; 
  font-weight: 500; 
}

.rating-stars { 
  display: flex; 
  gap: 16rpx; 
}

.star { 
  font-size: 56rpx; 
  color: rgba(255,255,255,0.15); 
}

.star-on { 
  color: #F5C869; 
  text-shadow: 0 0 10rpx rgba(245,200,105,0.6); 
}

.rating-hint { 
  font-size: 26rpx; 
  color: #8BA3B9; 
}

/* 睡眠时间线 */
.sleep-timeline { 
  display: flex; 
  flex-direction: column; 
  align-items: stretch; 
  margin: 4rpx 0; 
  width: 100%;
  box-sizing: border-box;
}

.timeline-item { 
  display: flex; 
  align-items: center; 
  gap: 16rpx; 
  padding: 2rpx 0; 
  width: 100%;
  box-sizing: border-box;
}

.timeline-dot { 
  width: 16rpx; 
  height: 16rpx; 
  border-radius: 50%; 
  flex-shrink: 0; 
}

.dot-sleep { 
  background: #6B9FD4; 
}

.dot-wake { 
  background: #F5C869; 
}

.dot-duration { 
  background: #7EC8A3; 
}

.timeline-line { 
  width: 2rpx; 
  height: 6rpx; 
  background: rgba(255,255,255,0.1); 
  margin-left: 7rpx; 
}

.timeline-content { 
  flex: 1; 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  padding: 12rpx 0; 
  border-bottom: 1rpx solid rgba(255,255,255,0.05); 
  min-width: 0;
  overflow: hidden;
}

.timeline-label { 
  font-size: 26rpx; 
  color: #8BA3B9; 
}

.timeline-value { 
  font-size: 28rpx; 
  color: #F0F4F8; 
  font-weight: 500; 
}

/* 睡眠柱 */
.sleep-bars { 
  display: flex; 
  align-items: flex-end; 
  gap: 12rpx; 
  height: 140rpx; 
  margin-top: 20rpx; 
  width: 100%;
  box-sizing: border-box;
}

.sleep-bar-col { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  gap: 12rpx; 
  height: 100%; 
  min-width: 0;
}

.sleep-bar-bg { 
  flex: 1; 
  width: 100%; 
  background: rgba(36,52,71,0.8); 
  border-radius: 10rpx; 
  overflow: hidden; 
  display: flex; 
  align-items: flex-end; 
}

.sleep-bar { 
  width: 100%; 
  border-radius: 10rpx; 
}

.sleep-bar-good { 
  background: linear-gradient(to top, rgba(126,200,163,0.8),rgba(126,200,163,0.3)); 
}

.sleep-bar-fair { 
  background: linear-gradient(to top, rgba(245,200,105,0.8),rgba(245,200,105,0.3)); 
}

.sleep-bar-poor { 
  background: linear-gradient(to top, rgba(232,132,107,0.8),rgba(232,132,107,0.3)); 
}

.sleep-bar-day { 
  font-size: 24rpx; 
  color: #8BA3B9; 
}

/* ========== 焦虑趋势 ========== */
.trend-chart { 
  display: flex; 
  align-items: flex-end; 
  gap: 12rpx; 
  height: 140rpx; 
  padding: 16rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.trend-col { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  gap: 12rpx; 
  height: 100%; 
  min-width: 0;
}

.trend-bar-bg { 
  flex: 1; 
  width: 100%; 
  background: rgba(36,52,71,0.8); 
  border-radius: 10rpx; 
  overflow: hidden; 
  display: flex; 
  align-items: flex-end; 
}

.trend-bar { 
  width: 100%; 
  border-radius: 10rpx; 
}

.trend-normal { 
  background: linear-gradient(to top, rgba(126,200,163,0.8),rgba(126,200,163,0.3)); 
}

.trend-mild { 
  background: linear-gradient(to top, rgba(245,200,105,0.8),rgba(245,200,105,0.3)); 
}

.trend-moderate { 
  background: linear-gradient(to top, rgba(107,159,212,0.8),rgba(107,159,212,0.3)); 
}

.trend-severe { 
  background: linear-gradient(to top, rgba(232,132,107,0.8),rgba(232,132,107,0.3)); 
}

.trend-day { 
  font-size: 24rpx; 
  color: #8BA3B9; 
}

.trend-insight { 
  margin-top: 28rpx; 
  padding-top: 24rpx; 
  border-top: 1rpx solid rgba(255,255,255,0.05); 
}

.insight-text { 
  font-size: 28rpx; 
  color: #8BA3B9; 
  font-style: italic; 
}

/* ========== 报告浮层 ========== */
.report-overlay { 
  position: fixed; 
  inset: 0; 
  background: rgba(13,27,42,0.8); 
  backdrop-filter: blur(20rpx); 
  display: flex; 
  align-items: flex-end; 
  z-index: 300; 
}

.report-sheet { 
  width: 100%; 
  max-height: 85vh; 
  background: linear-gradient(180deg,rgba(36,52,71,0.98),rgba(27,40,56,0.99)); 
  border-radius: 40rpx 40rpx 0 0; 
  border-top: 1rpx solid rgba(255,255,255,0.1); 
  display: flex; 
  flex-direction: column; 
}

.sheet-handle { 
  width: 60rpx; 
  height: 6rpx; 
  background: rgba(255,255,255,0.2); 
  border-radius: 3rpx; 
  margin: 20rpx auto; 
}

.sheet-header { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  padding: 24rpx 40rpx 20rpx;
  padding-right: calc(40rpx + env(safe-area-inset-right));
  border-bottom: 1rpx solid rgba(255,255,255,0.06); 
}

.sheet-title { 
  font-size: 36rpx; 
  font-weight: 600; 
  color: #F0F4F8; 
}

.sheet-close { 
  width: 56rpx; 
  height: 56rpx; 
  border-radius: 50%; 
  background: rgba(255,255,255,0.08); 
  color: #8BA3B9; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  font-size: 32rpx; 
}

.sheet-content { 
  flex: 1; 
  padding: 32rpx 40rpx;
  padding-right: calc(40rpx + env(safe-area-inset-right));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto; 
}

/* 报告区块 */
.report-section { 
  margin-bottom: 40rpx; 
}

.report-section-title { 
  font-size: 30rpx; 
  font-weight: 600; 
  color: #F0F4F8; 
  margin-bottom: 24rpx; 
}

/* 睡眠效率大圆环 */
.se-big-display { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 40rpx 0; 
}

.se-circle { 
  width: 200rpx; 
  height: 200rpx; 
  border-radius: 50%; 
  border: 10rpx solid; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  position: relative; 
}

.se-circle-value { 
  font-size: 64rpx; 
  font-weight: 300; 
  color: #F0F4F8; 
}

.se-circle-unit { 
  font-size: 28rpx; 
  color: #8BA3B9; 
  position: absolute; 
  bottom: 56rpx; 
}

.se-circle-label { 
  font-size: 28rpx; 
  color: #8BA3B9; 
  margin-top: 24rpx; 
}

.dashboard-kpi-row { 
  display: flex; 
  gap: 20rpx; 
}

.dashboard-kpi { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 28rpx 20rpx;
  background: rgba(255,255,255,0.05); 
  border-radius: 20rpx; 
}

.kpi-value { 
  font-size: 40rpx; 
  font-weight: 700; 
  color: #F0F4F8; 
  margin-bottom: 6rpx;
}

.kpi-label { 
  font-size: 22rpx; 
  color: #8BA3B9; 
}

/* SE 趋势图 */
.se-trend-chart { 
  display: flex; 
  align-items: flex-end; 
  gap: 16rpx; 
  height: 180rpx; 
  padding: 24rpx; 
}

.se-trend-col { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  gap: 8rpx;
}

.se-trend-bar-bg { 
  flex: 1; 
  width: 100%; 
  background: rgba(36,52,71,0.6); 
  border-radius: 8rpx; 
  overflow: hidden; 
  display: flex; 
  align-items: flex-end; 
}

.se-trend-bar { 
  width: 100%; 
  border-radius: 8rpx;
}

.se-trend-bar.se-good { 
  background: linear-gradient(to top, rgba(126,200,163,0.9), rgba(126,200,163,0.4)); 
}

.se-trend-bar.se-fair { 
  background: linear-gradient(to top, rgba(245,200,105,0.9), rgba(245,200,105,0.4)); 
}

.se-trend-bar.se-poor { 
  background: linear-gradient(to top, rgba(232,132,107,0.9), rgba(232,132,107,0.4)); 
}

.se-trend-day { 
  font-size: 22rpx; 
  color: #8BA3B9; 
}

.se-trend-value { 
  font-size: 22rpx; 
  color: #F0F4F8; 
  font-weight: 500; 
}

/* 建议卡片 */
.recommendation-card { 
  background: rgba(107,159,212,0.08); 
  border-radius: 20rpx; 
  padding: 28rpx; 
  display: flex; 
  flex-direction: column; 
  gap: 24rpx;
  border: 1rpx solid rgba(107,159,212,0.12);
}

.rec-item { 
  display: flex; 
  gap: 20rpx; 
  align-items: flex-start; 
}

.rec-icon { 
  font-size: 40rpx; 
}

.rec-content { 
  flex: 1; 
  display: flex; 
  flex-direction: column; 
  gap: 8rpx; 
}

.rec-title { 
  font-size: 28rpx; 
  font-weight: 600; 
  color: #F0F4F8; 
}

.rec-text { 
  font-size: 26rpx; 
  color: #8BA3B9; 
  line-height: 1.6;
}

/* 空状态详情 */
.dashboard-empty-detail { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  padding: 80rpx 48rpx; 
  gap: 24rpx;
}

.dashboard-empty-detail .dashboard-empty-icon { 
  font-size: 88rpx; 
}

.dashboard-empty-title { 
  font-size: 36rpx; 
  font-weight: 600; 
  color: #F0F4F8; 
}

.dashboard-empty-desc { 
  font-size: 28rpx; 
  color: #8BA3B9; 
  text-align: center; 
  line-height: 1.8;
}
