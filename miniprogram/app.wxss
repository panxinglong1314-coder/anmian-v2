/* app.wxss - 全局样式 + 毛玻璃设计系统 */
/* 睡前大脑关机助手 */

/* ============================================================
   CSS 变量
   ============================================================ */
:root {
  --bg-primary: #0D1B2A;
  --bg-secondary: #1B2838;
  --bg-card: rgba(36, 52, 71, 0.6);
  --bg-glass: rgba(36, 52, 71, 0.45);
  --bg-glass-light: rgba(58, 90, 124, 0.35);
  --bg-glass-heavy: rgba(13, 27, 42, 0.75);

  --accent-gold: #F5C869;
  --accent-blue: #6B9FD4;
  --accent-green: #7EC8A3;
  --accent-coral: #E8846B;

  --text-primary: #EDE8DF;
  /* 【2026-05-15】统一二级文字色：#8BA3B9 = rgb(139,163,185)，
     与全局 rgba(139,163,185,X) alpha 形式一致，避免双灰蓝混用 */
  --text-secondary: #8BA3B9;
  /* 【2026-05-15】提亮 muted：原 var(--text-muted) 对 #0D1B2A 仅 3.4:1（不达 WCAG AA），
     提亮到 #6B7F95 → 4.5:1+ */
  --text-muted: #6B7F95;

  --border-glass: rgba(255, 255, 255, 0.08);
  --border-glass-bright: rgba(255, 255, 255, 0.15);

  --shadow-glass: 0 8rpx 32rpx rgba(13, 27, 42, 0.5);
  --shadow-glow-gold: 0 0 24rpx rgba(245, 200, 105, 0.25);
  --shadow-glow-blue: 0 0 20rpx rgba(107, 159, 212, 0.2);
  --shadow-glow-green: 0 0 20rpx rgba(126, 200, 163, 0.25);
  --shadow-card-gold: 0 8rpx 32rpx rgba(245, 200, 105, 0.08);
  --shadow-breathing: 0 0 40rpx rgba(126, 200, 163, 0.3);

  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 40rpx;

  --blur-light: blur(16rpx);
  --blur-medium: blur(24rpx);
  --blur-heavy: blur(40rpx);
}

/* ============================================================
   全局重置
   ============================================================ */
page {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  min-height: 100vh;
}

/* ============================================================
   毛玻璃工具类
   ============================================================ */

/* 标准毛玻璃卡片 */
.glass-card {
  background: var(--bg-glass);
  backdrop-filter: blur(var(--blur-light));
  -webkit-backdrop-filter: blur(var(--blur-light));
  border: 1rpx solid var(--border-glass);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-glass);
}

/* 强毛玻璃（用于弹窗/浮层） */
.glass-card-strong {
  background: var(--bg-glass-heavy);
  backdrop-filter: blur(var(--blur-medium));
  -webkit-backdrop-filter: blur(var(--blur-medium));
  border: 1rpx solid var(--border-glass-bright);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-glass);
}

/* 轻毛玻璃（用于输入区/工具条） */
.glass-bar {
  background: rgba(27, 40, 56, 0.8);
  backdrop-filter: blur(var(--blur-heavy));
  -webkit-backdrop-filter: blur(var(--blur-heavy));
  border-top: 1rpx solid var(--border-glass);
}

/* 毛玻璃按钮 */
.glass-btn {
  background: var(--bg-glass);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border: 1rpx solid var(--border-glass-bright);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 28rpx;
  transition: all 0.25s ease;
}

.glass-btn:active {
  transform: scale(0.97);
  background: var(--bg-glass-light);
}

/* 毛玻璃主按钮 */
.glass-btn-primary {
  background: linear-gradient(
    135deg,
    rgba(245, 200, 105, 0.35) 0%,
    rgba(245, 200, 105, 0.15) 100%
  );
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(245, 200, 105, 0.4);
  border-radius: var(--radius-md);
  color: var(--accent-gold);
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: var(--shadow-glow-gold);
  transition: all 0.25s ease;
}

.glass-btn-primary:active {
  transform: scale(0.97);
  background: linear-gradient(
    135deg,
    rgba(245, 200, 105, 0.5) 0%,
    rgba(245, 200, 105, 0.25) 100%
  );
}

/* 内发光文字 */
.glow-text-gold {
  color: var(--accent-gold);
  text-shadow: 0 0 12rpx rgba(245, 200, 105, 0.4);
}

.glow-text-blue {
  color: var(--accent-blue);
  text-shadow: 0 0 12rpx rgba(107, 159, 212, 0.4);
}

.glow-text-green {
  color: var(--accent-green);
  text-shadow: 0 0 12rpx rgba(126, 200, 163, 0.4);
}

/* ============================================================
   渐变背景圆角区块
   ============================================================ */
.gradient-card {
  border-radius: var(--radius-lg);
  position: relative;
  overflow: hidden;
}

.gradient-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    135deg,
    rgba(107, 159, 212, 0.08) 0%,
    rgba(126, 200, 163, 0.05) 50%,
    rgba(245, 200, 105, 0.05) 100%
  );
  pointer-events: none;
}

/* 顶部边框高光 */
.top-border-glow {
  border-top: 1rpx solid rgba(107, 159, 212, 0.3);
}

/* ============================================================
   通用布局
   ============================================================ */
.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* 通用标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 通用副标题 */
.section-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

/* ============================================================
   滚动区域
   ============================================================ */
.scroll-view {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 自定义滚动条（仅深色主题） */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--bg-card);
  border-radius: 2rpx;
}
